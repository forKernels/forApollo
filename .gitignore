# Upstream dependency SOURCE — never commit .f90 from other libraries
# deps/lib/*.a and deps/zig/*.zig ARE committed (stripped prebuilts only)
deps/**/src/
deps/**/*.f90
deps/**/*.md

# Prebuilt forApollo objects (platform-specific, committed for distribution)
# prebuilt/ is tracked — contains multi-platform .a for users who skip building

# Zig build output
zig-out/
zig-cache/
.zig-cache/

# Python
__pycache__/
*.pyc
*.egg-info/
venv/

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Linker files
*.ilk

# Debugger Files
*.pdb

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# debug information files
*.dwo
